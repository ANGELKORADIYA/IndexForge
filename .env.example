# Database Configuration
POSTGRES_DB=memory_search
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/memory_search

# Paths
TANTIVY_PATH=./data/tantivy-index
MODEL_PATH=./models

# Server Configuration
SERVER_PORT=8080
LOG_LEVEL=info

# --- Phase 3: RAG LLM Provider Configuration ---
# The RAG pipeline will use the first API key it finds in this order: Gemini -> OpenRouter -> Ollama (local)

# Option 1: Gemini (Google)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-pro-latest

# Option 2: OpenRouter (Cloud)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# Option 3: Ollama (100% Offline Local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
